#!/bin/sh
# pit-boss CLI entry point

SCRIPT_DIR=$(cd "$(dirname "$0")/.." && pwd)

COMMAND="$1"
shift 2>/dev/null || true

case "$COMMAND" in
  seed)
    if [ "${1:-}" = "apply" ]; then
      shift
      bash "$SCRIPT_DIR/commands/apply-seed.sh" "$@"
    else
      sh "$SCRIPT_DIR/commands/seed.sh" "$@"
    fi
    ;;
  apply)
    if [ "${1:-}" = "run" ]; then
      shift
      bash "$SCRIPT_DIR/commands/apply-config.sh" "$@"
    else
      sh "$SCRIPT_DIR/commands/apply.sh" "$@"
    fi
    ;;
  migration)
    sh "$SCRIPT_DIR/commands/migration.sh" "$@"
    ;;
  pre-commit)
    sh "$SCRIPT_DIR/pre-commit/resolve-seed-max.sh" "$@"
    ;;
  secrets|s|vars|variables|v)
    sh "$SCRIPT_DIR/bin/tokens" "$COMMAND" "$@"
    ;;
  ""|--help|-h)
    printf 'Usage: pit-boss <command> [options]\n'
    printf '\n'
    printf 'Commands:\n'
    printf '  migration <name>          Scaffold a new migration file pair\n'
    printf '  seed <file>               Annotate seed with MIN=highest, MAX=open\n'
    printf '  seed <file> locked        Annotate seed with MIN=MAX=highest\n'
    printf '  seed <file> --min=N       Annotate seed with MIN=N, NEEDS_VERIFICATION=true\n'
    printf '  seed apply [options]      Apply the newest compatible seed\n'
    printf '  apply <name>              Scaffold a new apply JSON file\n'
    printf '  apply run [options]       Apply a versioned config through Oboist\n'
    printf '  pre-commit                Resolve open MIGRATION_MAX values (run as hook)\n'
    printf '  secrets, s [options]      Push secrets from tokens.yml to Cloudflare\n'
    printf '  vars, variables, v [opt]  Append variables to wrangler.toml and deploy\n'
    printf '    -c/--config <path>        wrangler config (sibling tokens.yml auto-found)\n'
    printf '    -t/--tokens <path>        tokens.yml (sibling wrangler config auto-found)\n'
    printf '    -f/--force                skip missing values instead of erroring\n'
    ;;
  *)
    printf 'Unknown command: %s\n' "$COMMAND" >&2
    printf 'Run pit-boss --help for usage.\n' >&2
    exit 1
    ;;
esac

#!/bin/sh
# pit-boss tokens subcommand: secrets

SUBCOMMAND="$1"
shift 2>/dev/null || true

URL_FLAG=""
SECRET_FLAG=""
ENV_FILE=""
INLINE_VALUES=""
INLINE_ALIAS=""
KEY_FILTER=""
ISOLATED=0
FORCE=0

while [ $# -gt 0 ]; do
  case "$1" in
    --url|-u)
      URL_FLAG="$2"
      shift 2
      ;;
    --secret|-s)
      SECRET_FLAG="$2"
      shift 2
      ;;
    --env|-e)
      ENV_FILE="$2"
      shift 2
      ;;
    --tokens|--token|-t)
      _alias="$1"
      if [ -n "$INLINE_ALIAS" ] && [ "$INLINE_ALIAS" != "$_alias" ]; then
        printf 'Error: cannot mix token flag aliases (%s and %s). Use one consistently.\n' "$INLINE_ALIAS" "$_alias" >&2
        exit 1
      fi
      INLINE_ALIAS="$_alias"
      if [ -n "$INLINE_VALUES" ]; then
        INLINE_VALUES="${INLINE_VALUES}
${2}"
      else
        INLINE_VALUES="$2"
      fi
      shift 2
      ;;
    --keys|--key|-k)
      if [ -n "$KEY_FILTER" ]; then
        KEY_FILTER="${KEY_FILTER}
${2}"
      else
        KEY_FILTER="$2"
      fi
      shift 2
      ;;
    --isolated|-i)
      ISOLATED=1
      shift
      ;;
    --force|-f)
      FORCE=1
      shift
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      exit 1
      ;;
  esac
done

PIT_BOSS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Normalize a raw token/key string into newline-separated KEY=VALUE or KEY pairs.
# Separators: newline, comma, semicolon, space (already split by shell if unquoted).
# KV separators: = or :
normalize_pairs() {
  printf '%s' "$1" | sed 's/[,;]/\n/g' | sed 's/^ *//;s/ *$//' | grep -v '^$'
}

# Parse normalized lines into INLINE_KV format: \nKEY\nVALUE\n...
# Returns: sets _out_kv
parse_kv_lines() {
  _raw="$1"
  _out_kv=""
  _IFS_SAVE="$IFS"
  IFS='
'
  for _line in $(printf '%s\n' "$_raw"); do
    IFS="$_IFS_SAVE"
    _line="$(printf '%s' "$_line" | sed 's/^ *//;s/ *$//')"
    [ -z "$_line" ] && continue
    # Try = first, then :
    if printf '%s' "$_line" | grep -q '='; then
      _k="${_line%%=*}"
      _v="${_line#*=}"
    elif printf '%s' "$_line" | grep -q ':'; then
      _k="${_line%%:*}"
      _v="${_line#*:}"
    else
      printf 'Error: invalid token format "%s" (expected KEY=value or KEY:value)\n' "$_line" >&2
      exit 1
    fi
    _k="$(printf '%s' "$_k" | sed 's/^ *//;s/ *$//')"
    _v="$(printf '%s' "$_v" | sed 's/^ *//;s/ *$//')"
    if [ -z "$_k" ]; then
      printf 'Error: empty key in token "%s"\n' "$_line" >&2
      exit 1
    fi
    _out_kv="${_out_kv}
${_k}
${_v}"
  done
  IFS="$_IFS_SAVE"
  printf '%s' "$_out_kv"
}

# Look up a key in a KV string (format: \nKEY\nVALUE\n...)
kv_lookup() {
  _kv="$1"
  _key="$2"
  printf '%s\n' "$_kv" | awk -v k="$_key" 'found{print;exit} $0==k{found=1}'
}

# Check if a key exists in a KV string
kv_has() {
  _v="$(kv_lookup "$1" "$2")"
  [ -n "$_v" ]
}

# Merge src KV into dst KV; dst wins on duplicate keys
kv_merge() {
  _dst="$1"
  _src="$2"
  _result="$_dst"
  _IFS_SAVE="$IFS"
  IFS='
'
  _reading_key=0
  _cur_key=""
  for _tok in $(printf '%s\n' "$_src"); do
    IFS="$_IFS_SAVE"
    [ -z "$_tok" ] && continue
    if [ "$_reading_key" = "0" ]; then
      _cur_key="$_tok"
      _reading_key=1
    else
      if ! kv_has "$_result" "$_cur_key"; then
        _result="${_result}
${_cur_key}
${_tok}"
      fi
      _reading_key=0
      _cur_key=""
    fi
  done
  IFS="$_IFS_SAVE"
  printf '%s' "$_result"
}

# Parse KEY=VALUE lines from an env file into KV string, skipping keys starting with _
# (unless include_private=1)
parse_env_file() {
  _file="$1"
  _include_private="${2:-0}"
  _result=""
  while IFS= read -r _line || [ -n "$_line" ]; do
    case "$_line" in
      ''|'#'*) continue ;;
    esac
    _k="${_line%%=*}"
    _v="${_line#*=}"
    _v="$(printf '%s' "$_v" | sed 's/^"//;s/"$//')"
    [ -z "$_k" ] || [ -z "$_v" ] && continue
    if [ "$_include_private" = "0" ]; then
      case "$_k" in
        _*) continue ;;
      esac
    fi
    _result="${_result}
${_k}
${_v}"
  done < "$_file"
  printf '%s' "$_result"
}

# Lookup a key across env files with underscore-prefixed priority
# lookup_auth KEY file1 file2 ...
lookup_auth() {
  _akey="$1"
  shift
  for _f in "$@"; do
    [ -f "$_f" ] || continue
    _v="$(grep -m1 "^_${_akey}=" "$_f" 2>/dev/null | cut -d= -f2- | sed 's/^"//;s/"$//')"
    [ -n "$_v" ] && { printf '%s' "$_v"; return; }
  done
  for _f in "$@"; do
    [ -f "$_f" ] || continue
    _v="$(grep -m1 "^${_akey}=" "$_f" 2>/dev/null | cut -d= -f2- | sed 's/^"//;s/"$//')"
    [ -n "$_v" ] && { printf '%s' "$_v"; return; }
  done
}

# Normalize --keys/-k input into newline-separated key names
normalize_keys() {
  printf '%s' "$1" | sed 's/[,;]/\n/g' | sed 's/^ *//;s/ *$//' | grep -v '^$'
}

case "$SUBCOMMAND" in
  secrets|s)
    # --- Build inline KV (--tokens/-t flags) ---
    INLINE_KV=""
    if [ -n "$INLINE_VALUES" ]; then
      _normalized="$(normalize_pairs "$INLINE_VALUES")"
      INLINE_KV="$(parse_kv_lines "$_normalized")"
    fi

    # --- Read piped stdin ---
    PIPED_KV=""
    if [ ! -t 0 ]; then
      _piped_raw="$(cat)"
      if [ -n "$_piped_raw" ]; then
        _normalized="$(normalize_pairs "$_piped_raw")"
        PIPED_KV="$(parse_kv_lines "$_normalized")"
      fi
    fi

    # --- Resolve env files ---
    ENV_FILES=""
    _add_env() {
      _f="$1"
      case "$ENV_FILES" in *"$_f"*) ;; *) [ -f "$_f" ] && ENV_FILES="${ENV_FILES} $_f" ;; esac
    }
    [ -n "$ENV_FILE" ] && { [ -f "$ENV_FILE" ] || { printf 'Error: env file not found: %s\n' "$ENV_FILE" >&2; exit 1; }; _add_env "$ENV_FILE"; }
    _add_env "./.env"
    _add_env "${PIT_BOSS_ROOT}/.env"
    _add_env "${PIT_BOSS_ROOT}/bin/.env"

    # --- Resolve PROXY_URL and PROXY_SECRET ---
    PROXY_URL="$URL_FLAG"
    PROXY_SECRET="$SECRET_FLAG"

    if [ -z "$PROXY_URL" ]; then
      # Check inline/piped first with underscore priority
      for _prefix in "_PROXY_URL" "PROXY_URL"; do
        if kv_has "$INLINE_KV" "$_prefix"; then
          PROXY_URL="$(kv_lookup "$INLINE_KV" "$_prefix")"
          break
        fi
        if kv_has "$PIPED_KV" "$_prefix"; then
          PROXY_URL="$(kv_lookup "$PIPED_KV" "$_prefix")"
          break
        fi
      done
    fi
    if [ -z "$PROXY_URL" ]; then
      PROXY_URL="$(lookup_auth "PROXY_URL" $ENV_FILES)"
    fi

    if [ -z "$PROXY_SECRET" ]; then
      for _prefix in "_PROXY_SECRET" "PROXY_SECRET"; do
        if kv_has "$INLINE_KV" "$_prefix"; then
          PROXY_SECRET="$(kv_lookup "$INLINE_KV" "$_prefix")"
          break
        fi
        if kv_has "$PIPED_KV" "$_prefix"; then
          PROXY_SECRET="$(kv_lookup "$PIPED_KV" "$_prefix")"
          break
        fi
      done
    fi
    if [ -z "$PROXY_SECRET" ]; then
      PROXY_SECRET="$(lookup_auth "PROXY_SECRET" $ENV_FILES)"
    fi

    if [ -z "$PROXY_URL" ]; then
      printf 'Error: PROXY_URL is not set.\n' >&2
      exit 1
    fi
    if [ -z "$PROXY_SECRET" ]; then
      printf 'Error: PROXY_SECRET is not set.\n' >&2
      exit 1
    fi

    # --- Build final secrets KV ---
    # Inline and piped always included; merge in order (inline wins over piped)
    SECRETS_KV="$(kv_merge "$INLINE_KV" "$PIPED_KV")"

    if [ "$ISOLATED" = "1" ]; then
      # In isolated mode, inline+piped are always included (fused tier 1).
      # If they have content, skip file sources. Otherwise walk files and stop at first hit.
      if [ -z "$SECRETS_KV" ]; then
        if [ -n "$ENV_FILE" ] && [ -f "$ENV_FILE" ]; then
          _fkv="$(parse_env_file "$ENV_FILE")"
          [ -n "$_fkv" ] && SECRETS_KV="$_fkv"
        fi
        if [ -z "$SECRETS_KV" ]; then
          for _f in "./.env" "${PIT_BOSS_ROOT}/.env" "${PIT_BOSS_ROOT}/bin/.env"; do
            [ -f "$_f" ] || continue
            _fkv="$(parse_env_file "$_f")"
            if [ -n "$_fkv" ]; then
              SECRETS_KV="$_fkv"
              break
            fi
          done
        fi
      fi
    else
      # Additive: merge all file sources
      if [ -n "$ENV_FILE" ] && [ -f "$ENV_FILE" ]; then
        _fkv="$(parse_env_file "$ENV_FILE")"
        SECRETS_KV="$(kv_merge "$SECRETS_KV" "$_fkv")"
      fi
      for _f in "./.env" "${PIT_BOSS_ROOT}/.env" "${PIT_BOSS_ROOT}/bin/.env"; do
        [ -f "$_f" ] || continue
        _fkv="$(parse_env_file "$_f")"
        SECRETS_KV="$(kv_merge "$SECRETS_KV" "$_fkv")"
      done
    fi

    # --- Apply -k/--keys filter ---
    if [ -n "$KEY_FILTER" ]; then
      NORMALIZED_KEYS="$(normalize_keys "$KEY_FILTER")"
      FILTERED_KV=""
      _IFS_SAVE="$IFS"
      IFS='
'
      for _k in $NORMALIZED_KEYS; do
        IFS="$_IFS_SAVE"
        [ -z "$_k" ] && continue
        if kv_has "$SECRETS_KV" "$_k"; then
          _v="$(kv_lookup "$SECRETS_KV" "$_k")"
          FILTERED_KV="${FILTERED_KV}
${_k}
${_v}"
        else
          if [ "$FORCE" = "1" ]; then
            printf 'Warning: key "%s" not found, skipping.\n' "$_k" >&2
          else
            printf 'Error: key "%s" not found. Use --force to skip missing keys.\n' "$_k" >&2
            exit 1
          fi
        fi
      done
      IFS="$_IFS_SAVE"
      SECRETS_KV="$FILTERED_KV"
    fi

    # --- Build JSON and POST ---
    SECRETS_JSON=""
    _IFS_SAVE="$IFS"
    IFS='
'
    _reading_key=0
    _cur_key=""
    for _tok in $(printf '%s\n' "$SECRETS_KV"); do
      IFS="$_IFS_SAVE"
      [ -z "$_tok" ] && continue
      if [ "$_reading_key" = "0" ]; then
        _cur_key="$_tok"
        _reading_key=1
      else
        _val_escaped="$(printf '%s' "$_tok" | sed 's/\\/\\\\/g;s/"/\\"/g;s/	/\\t/g')"
        if [ -n "$SECRETS_JSON" ]; then
          SECRETS_JSON="${SECRETS_JSON},\"${_cur_key}\":\"${_val_escaped}\""
        else
          SECRETS_JSON="\"${_cur_key}\":\"${_val_escaped}\""
        fi
        _reading_key=0
        _cur_key=""
      fi
    done
    IFS="$_IFS_SAVE"

    if [ -z "$SECRETS_JSON" ]; then
      printf 'No secrets found.\n'
      exit 0
    fi

    BODY="{\"secrets\":{${SECRETS_JSON}}}"
    ENDPOINT="${PROXY_URL%/}/pit-boss/secrets/push"

    printf 'Posting secrets to %s\n' "$ENDPOINT"
    RESPONSE="$(curl -s -w '\n%{http_code}' \
      -X POST "$ENDPOINT" \
      -H "Authorization: Bearer ${PROXY_SECRET}" \
      -H "Content-Type: application/json" \
      -d "$BODY")"

    HTTP_STATUS="$(printf '%s' "$RESPONSE" | tail -n 1)"
    HTTP_BODY="$(printf '%s' "$RESPONSE" | sed '$d')"

    case "$HTTP_STATUS" in
      200|207)
        _ok_count=0
        _fail_count=0
        _IFS_SAVE="$IFS"
        IFS='
'
        for _entry in $(printf '%s' "$HTTP_BODY" | sed 's/},{/}|{/g' | tr '|' '\n'); do
          _name="$(printf '%s' "$_entry" | sed 's/.*"name":"\([^"]*\)".*/\1/')"
          _entry_ok="$(printf '%s' "$_entry" | sed 's/.*"ok":\([a-z]*\).*/\1/')"
          if [ "$_entry_ok" = "true" ]; then
            _ok_count=$(( _ok_count + 1 ))
            printf '  ok  %s\n' "$_name"
          else
            _fail_count=$(( _fail_count + 1 ))
            _cf_error="$(printf '%s' "$_entry" | sed 's/.*"error":"//;s/"}]*//')"
            _cf_summary="$(printf '%s' "$_cf_error" | sed 's/\[{\\".*//' | sed 's/^ *//;s/ *$//')"
            _cf_code="$(printf '%s' "$_cf_error" | sed 's/.*\\"code\\":\([0-9]*\).*/\1/')"
            _cf_message="$(printf '%s' "$_cf_error" | sed 's/.*\\"message\\":\\"//;s/\\"}.*//')"
            printf '\033[31mERR %s\033[0m %s\n' "$_name" "$_cf_summary" >&2
            printf '  \033[1m%s\033[0m %s\n' "$_cf_code" "$_cf_message" >&2
          fi
        done
        IFS="$_IFS_SAVE"
        if [ "$_fail_count" -gt 0 ]; then
          printf '\n\033[1;31m%d pushed, %d failed.\033[0m\n' "$_ok_count" "$_fail_count"
        else
          printf '\n\033[1;32m%d pushed, %d failed.\033[0m\n' "$_ok_count" "$_fail_count"
        fi
        [ "$_fail_count" -gt 0 ] && exit 1 || exit 0
        ;;
      *)
        printf 'Error: proxy returned HTTP %s.\n' "$HTTP_STATUS" >&2
        printf '%s\n' "$HTTP_BODY" >&2
        exit 1
        ;;
    esac
    ;;

  *)
    printf 'Usage: pit-boss secrets [options]\n'
    printf '\n'
    printf 'Options:\n'
    printf '  --url,      -u <url>      Proxy URL (overrides PROXY_URL / _PROXY_URL)\n'
    printf '  --secret,   -s <secret>   Proxy secret (overrides PROXY_SECRET / _PROXY_SECRET)\n'
    printf '  --env,      -e <file>     Path to a .env file\n'
    printf '  --tokens/--token/-t <kv>  Inline KEY=value or KEY:value pairs; may be passed\n'
    printf '                            multiple times; separators: comma, semicolon, newline\n'
    printf '                            All aliases used must match (cannot mix --token/--tokens)\n'
    printf '  --keys/--key/-k <keys>    Only send these keys; separators: comma, semicolon,\n'
    printf '                            newline, space (when quoted); may be passed multiple times\n'
    printf '  --isolated, -i            Stop at first source tier that yields content\n'
    printf '                            (inline+piped are always fused as tier 1)\n'
    printf '  --force,    -f            Warn instead of error on missing --keys entries\n'
    printf '\n'
    printf 'Source priority (additive by default; -i stops at first hit):\n'
    printf '  1. --tokens/-t inline\n'
    printf '  2. piped stdin (echo KEY=val | pit-boss secrets)\n'
    printf '  3. --env file\n'
    printf '  4. .env in current directory\n'
    printf '  5. .env in pit-boss root\n'
    printf '  6. .env in pit-boss/bin\n'
    printf '\n'
    printf 'Auth key lookup (_PROXY_* takes priority over PROXY_*):\n'
    printf '  --url/-u and --secret/-s flags take top priority, then sources in order above.\n'
    ;;
esac
